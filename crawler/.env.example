# Agentic AI Landscape Tracker - Environment Variables
# Copy this file to .env and fill in the values.

# Data output file path (e.g. ../data/entries.json)
CRAWLER_OUTPUT_PATH=

# Backfill settings
CRAWLER_BACKFILL_ENABLED=
CRAWLER_BACKFILL_START_DATE=

# Crawler behavior
CRAWLER_DELAY_BETWEEN_REQUESTS=
CRAWLER_MAX_RETRIES=
CRAWLER_TIMEOUT=

# Sources - JSON array of source objects.
# Each source object must have: name, type, url, selectors (with article_list, title, date, link).
# Optional fields: rss_url, enabled.
CRAWLER_SOURCES=

# Categories - JSON array of category strings used for classification.
CRAWLER_CATEGORIES=
